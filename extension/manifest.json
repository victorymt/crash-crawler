{
  "manifest_version": 3,
  "name": "Provider Usage Hub",
  "description": "Browser extension dashboard for provider balances, usage, subscriptions, and coupons.",
  "version": "0.1.0",
  "action": {
    "default_title": "Provider Usage Hub",
    "default_popup": "src/popup/popup.html"
  },
  "options_page": "src/options/options.html",
  "background": {
    "service_worker": "src/background/service_worker.js",
    "type": "module"
  },
  "permissions": [
    "storage",
    "tabs",
    "scripting"
  ],
  "host_permissions": [
    "https://opencode.ai/*",
    "https://platform.deepseek.com/*",
    "https://api.deepseek.com/*",
    "https://www.ezaiclub.com/*",
    "https://cloud.siliconflow.cn/*",
    "https://account.siliconflow.cn/*"
  ],
  "optional_host_permissions": [
    "https://*/*",
    "http://*/*"
  ]
}
